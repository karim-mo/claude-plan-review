{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2022",
		"outDir": "out",
		"rootDir": "src",
		"lib": ["es2022"],
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["node", "vscode"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "out", "dist", ".vscode-test", "src/webview"]
}
